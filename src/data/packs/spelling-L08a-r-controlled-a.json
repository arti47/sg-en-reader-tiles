  "lessons": {
    "SP-r-controlled-a": {
      "iCanStatement": "I can spell words with ar and or.",
      "explanation": "For the /ar/ sound use ar (car, park). For the /or/ sound use or (fork, corn). Pick the r-team tile — don't split it into two letters.",
      "workedExamples": [
        {
          "text": "park",
          "note": "Hear p-ar-k → p · ar · k"
        },
        {
          "text": "corn",
          "note": "Hear c-or-n → c · or · n"
        }
      ]
    }
  }
