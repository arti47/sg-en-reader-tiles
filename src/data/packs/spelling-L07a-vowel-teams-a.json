  "lessons": {
    "SP-vowel-teams-a": {
      "iCanStatement": "I can spell words with the ai, ay, ee and ea teams.",
      "explanation": "For long a, use ai in the middle (rain) and ay at the end (play). For long e, use ee (feet) or ea (leaf). Pick the right team tile for the sound.",
      "workedExamples": [
        {
          "text": "play",
          "note": "Long a at the end → p · l · ay"
        },
        {
          "text": "leaf",
          "note": "Long e → l · ea · f"
        }
      ]
    }
  }
