{
  "packId": "sm-L01-editing",
  "strand": "sentence",
  "skillIds": ["SM-editing"],
  "version": 1,
  "items": [
    { "id": "sm-ed-01", "skillId": "SM-editing", "itemType": "editing_mcq", "difficulty": 1, "stem": "One word is wrong: \"The children IS noisy today.\" Which word should replace IS?", "choices": [{ "id": "a", "label": "are" }, { "id": "b", "label": "am" }, { "id": "c", "label": "was" }], "correctChoiceId": "a", "missedConceptOnFail": "editing-grammar", "rationale": "'children' is plural, so the verb is 'are': The children are noisy." },
    { "id": "sm-ed-02", "skillId": "SM-editing", "itemType": "editing_mcq", "difficulty": 1, "stem": "One word is wrong: \"My sister GO to a new school.\" Which word should replace GO?", "choices": [{ "id": "a", "label": "goes" }, { "id": "b", "label": "going" }, { "id": "c", "label": "gone" }], "correctChoiceId": "a", "missedConceptOnFail": "editing-grammar", "rationale": "'sister' is singular, so the verb takes -es: goes." },
    { "id": "sm-ed-03", "skillId": "SM-editing", "itemType": "editing_mcq", "difficulty": 1, "stem": "One word is wrong: \"Yesterday we GO to the beach.\" Which word should replace GO?", "choices": [{ "id": "a", "label": "gone" }, { "id": "b", "label": "went" }, { "id": "c", "label": "going" }], "correctChoiceId": "b", "missedConceptOnFail": "editing-grammar", "rationale": "'Yesterday' means the past, so use 'went'." },
    { "id": "sm-ed-04", "skillId": "SM-editing", "itemType": "editing_mcq", "difficulty": 2, "stem": "One word is wrong: \"She has WROTE a letter.\" Which word should replace WROTE?", "choices": [{ "id": "a", "label": "writing" }, { "id": "b", "label": "wrote" }, { "id": "c", "label": "written" }], "correctChoiceId": "c", "missedConceptOnFail": "editing-grammar", "rationale": "After 'has', use the past participle: has written." },
    { "id": "sm-ed-05", "skillId": "SM-editing", "itemType": "editing_mcq", "difficulty": 2, "stem": "One word is wrong: \"I SEEN him at the mall.\" Which word should replace SEEN?", "choices": [{ "id": "a", "label": "saw" }, { "id": "b", "label": "seeing" }, { "id": "c", "label": "sees" }], "correctChoiceId": "a", "missedConceptOnFail": "editing-grammar", "rationale": "Without 'have', use the past tense 'saw'." },
    { "id": "sm-ed-06", "skillId": "SM-editing", "itemType": "editing_mcq", "difficulty": 2, "stem": "One word is wrong: \"He DON'T eat meat.\" Which word should replace DON'T?", "choices": [{ "id": "a", "label": "doesn't" }, { "id": "b", "label": "didn't" }, { "id": "c", "label": "isn't" }], "correctChoiceId": "a", "missedConceptOnFail": "editing-grammar", "rationale": "'He' is singular, so use 'doesn't'." },
    { "id": "sm-ed-07", "skillId": "SM-editing", "itemType": "editing_mcq", "difficulty": 2, "stem": "One word is wrong: \"There are three MOUSES in the shed.\" Which word should replace MOUSES?", "choices": [{ "id": "a", "label": "mouse" }, { "id": "b", "label": "mice" }, { "id": "c", "label": "mouses" }], "correctChoiceId": "b", "missedConceptOnFail": "editing-grammar", "rationale": "The plural of 'mouse' is 'mice'." },
    { "id": "sm-ed-08", "skillId": "SM-editing", "itemType": "editing_mcq", "difficulty": 3, "stem": "One word is wrong: \"She bought two LOAFS of bread.\" Which word should replace LOAFS?", "choices": [{ "id": "a", "label": "loaves" }, { "id": "b", "label": "loaf" }, { "id": "c", "label": "loafes" }], "correctChoiceId": "a", "missedConceptOnFail": "editing-grammar", "rationale": "The plural of 'loaf' is 'loaves'." },
    { "id": "sm-ed-09", "skillId": "SM-editing", "itemType": "editing_mcq", "difficulty": 2, "stem": "One word is wrong: \"He is A honest boy.\" Which word should replace A?", "choices": [{ "id": "a", "label": "an" }, { "id": "b", "label": "the" }, { "id": "c", "label": "one" }], "correctChoiceId": "a", "missedConceptOnFail": "editing-grammar", "rationale": "The 'h' in 'honest' is silent, so use 'an'." },
    { "id": "sm-ed-10", "skillId": "SM-editing", "itemType": "editing_mcq", "difficulty": 3, "stem": "One word is wrong: \"ME and Siti went home.\" Which word should replace ME?", "choices": [{ "id": "a", "label": "I" }, { "id": "b", "label": "My" }, { "id": "c", "label": "Mine" }], "correctChoiceId": "a", "missedConceptOnFail": "editing-grammar", "rationale": "As the subject, use 'I': Siti and I went home." },
    { "id": "sm-ed-11", "skillId": "SM-editing", "itemType": "editing_mcq", "difficulty": 2, "stem": "One word is wrong: \"The cat licked IT'S paw.\" Which word should replace IT'S?", "choices": [{ "id": "a", "label": "its" }, { "id": "b", "label": "it" }, { "id": "c", "label": "is" }], "correctChoiceId": "a", "missedConceptOnFail": "editing-grammar", "rationale": "'its' shows belonging; 'it's' means 'it is'." },
    { "id": "sm-ed-12", "skillId": "SM-editing", "itemType": "editing_mcq", "difficulty": 1, "stem": "One word is wrong: \"We visited malaysia last year.\" Which word should replace 'malaysia'?", "choices": [{ "id": "a", "label": "Malaysia" }, { "id": "b", "label": "Malaysian" }, { "id": "c", "label": "Malaysias" }], "correctChoiceId": "a", "missedConceptOnFail": "editing-capital", "rationale": "The country's name is 'Malaysia' — a proper noun with a capital letter." },
    { "id": "sm-ed-13", "skillId": "SM-editing", "itemType": "editing_mcq", "difficulty": 3, "stem": "One word is wrong: \"I RECIEVED a gift.\" Which word should replace RECIEVED?", "choices": [{ "id": "a", "label": "recieved" }, { "id": "b", "label": "received" }, { "id": "c", "label": "receeved" }], "correctChoiceId": "b", "missedConceptOnFail": "editing-spelling", "rationale": "'i before e except after c' → received." },
    { "id": "sm-ed-14", "skillId": "SM-editing", "itemType": "editing_mcq", "difficulty": 2, "stem": "One word is wrong: \"She is my best FREIND.\" Which word should replace FREIND?", "choices": [{ "id": "a", "label": "frend" }, { "id": "b", "label": "freind" }, { "id": "c", "label": "friend" }], "correctChoiceId": "c", "missedConceptOnFail": "editing-spelling", "rationale": "The correct spelling is 'friend'." },
    { "id": "sm-ed-15", "skillId": "SM-editing", "itemType": "editing_mcq", "difficulty": 3, "stem": "One word is wrong: \"The garden is BEUTIFUL.\" Which word should replace BEUTIFUL?", "choices": [{ "id": "a", "label": "beautiful" }, { "id": "b", "label": "beutiful" }, { "id": "c", "label": "beatiful" }], "correctChoiceId": "a", "missedConceptOnFail": "editing-spelling", "rationale": "The correct spelling is 'beautiful'." },
    { "id": "sm-ed-16", "skillId": "SM-editing", "itemType": "editing_mcq", "difficulty": 3, "stem": "One word is wrong: \"He DEFINATELY passed the test.\" Which word should replace DEFINATELY?", "choices": [{ "id": "a", "label": "definately" }, { "id": "b", "label": "definitly" }, { "id": "c", "label": "definitely" }], "correctChoiceId": "c", "missedConceptOnFail": "editing-spelling", "rationale": "The correct spelling is 'definitely'." },
    { "id": "sm-ed-17", "skillId": "SM-editing", "itemType": "editing_mcq", "difficulty": 3, "stem": "One word is wrong: \"Neither of the boys ARE here.\" Which word should replace ARE?", "choices": [{ "id": "a", "label": "is" }, { "id": "b", "label": "were" }, { "id": "c", "label": "am" }], "correctChoiceId": "a", "missedConceptOnFail": "editing-grammar", "rationale": "'Neither of...' takes a singular verb: is." },
    { "id": "sm-ed-18", "skillId": "SM-editing", "itemType": "editing_mcq", "difficulty": 1, "stem": "One word is wrong: \"They WAS watching TV.\" Which word should replace WAS?", "choices": [{ "id": "a", "label": "am" }, { "id": "b", "label": "were" }, { "id": "c", "label": "is" }], "correctChoiceId": "b", "missedConceptOnFail": "editing-grammar", "rationale": "'They' is plural, so use 'were'." },
    { "id": "sm-ed-19", "skillId": "SM-editing", "itemType": "editing_mcq", "difficulty": 2, "stem": "One word is wrong: \"She is good IN Maths.\" Which word should replace IN?", "choices": [{ "id": "a", "label": "at" }, { "id": "b", "label": "on" }, { "id": "c", "label": "with" }], "correctChoiceId": "a", "missedConceptOnFail": "editing-grammar", "rationale": "We say 'good at' something." },
    { "id": "sm-ed-20", "skillId": "SM-editing", "itemType": "editing_mcq", "difficulty": 2, "stem": "One word is wrong: \"He BUYED a new bag.\" Which word should replace BUYED?", "choices": [{ "id": "a", "label": "buys" }, { "id": "b", "label": "bought" }, { "id": "c", "label": "buyed" }], "correctChoiceId": "b", "missedConceptOnFail": "editing-grammar", "rationale": "The past tense of 'buy' is 'bought'." }
  ],
  "lessons": {
    "SM-editing": {
      "iCanStatement": "I can find and fix the wrong word in a sentence.",
      "explanation": "In editing, one word in the sentence is wrong — a spelling slip, the wrong verb form, a missing capital letter, or the wrong little word. Read the whole sentence, find the word that does not fit, and choose the correct one to replace it.",
      "workedExamples": [
        { "text": "The dogs BARKS loudly.", "note": "'dogs' is plural → the verb should be 'bark'." },
        { "text": "we live in singapore.", "note": "Names and sentence starts need capitals → We … Singapore." }
      ]
    }
  }
}
