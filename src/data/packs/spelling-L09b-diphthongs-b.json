  "lessons": {
    "SP-diphthongs-b": {
      "iCanStatement": "I can spell words with aw, au and short oo.",
      "explanation": "The /aw/ sound is aw at the end (saw) or au in the middle (haul). Short oo words like book, look, good use oo. Choose the right team tile.",
      "workedExamples": [
        {
          "text": "draw",
          "note": "/aw/ at the end → d · r · aw"
        },
        {
          "text": "good",
          "note": "short oo → g · oo · d"
        }
      ]
    }
  }
}
