  "lessons": {
    "VOC-antonyms": {
      "iCanStatement": "I can choose a word that means the opposite.",
      "explanation": "An antonym is a word that means the opposite. Read the word, then pick the choice that means the reverse — watch out for choices that mean almost the same thing (those are synonyms, not antonyms).",
      "workedExamples": [
        { "text": "hot ↔ cold", "note": "'cold' is the opposite of 'hot'." },
        { "text": "up ↔ down", "note": "'down' is the opposite of 'up'." }
