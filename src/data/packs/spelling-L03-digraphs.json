  "lessons": {
    "SP-digraphs": {
      "iCanStatement": "I can spell words with sh, ch, th and ck.",
      "explanation": "When you hear /sh/, /ch/ or /th/, use the two-letter tile — not two separate letters. When a short word ends in /k/ right after a short vowel, spell it 'ck' (duck, not 'duk').",
      "workedExamples": [
        { "text": "fish", "note": "Hear f-i-sh → tiles f · i · sh" },
        { "text": "rock", "note": "Hear r-o-ck → tiles r · o · ck" }
      ]
    }
  }
