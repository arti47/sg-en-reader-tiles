  "lessons": {
    "PH-cvc-4": {
      "iCanStatement": "I can read short words with j, v, w, x, y, z and qu.",
      "explanation": "The last sounds: j, v, w, x (/ks/), y, z, and qu (/kw/). Blend them to read: j-a-m → jam, b-o-x → box, qu-i-z → quiz. Now you know all the letter sounds!",
      "workedExamples": [
        {
          "text": "jam",
          "note": "j · a · m → jam"
        },
        {
          "text": "box",
          "note": "b · o · x → box"
        }
      ]
    }
  }
